{# report.jinja2 — 综合投资分析报告模板 #}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ ticker }} — 综合投资分析报告</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#0f172a;--blue:#2563eb;--blue-l:#3b82f6;--green:#059669;--red:#dc2626;--amber:#d97706;--slate:#64748b;--border:#e2e8f0;--bg:#f8fafc;--white:#fff;--text:#0f172a;--muted:#94a3b8;--r:8px;--sh:0 1px 3px rgba(0,0,0,.06)}
html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,'Inter','Helvetica Neue','PingFang SC','Microsoft YaHei',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.6}
.layout{display:flex;min-height:100vh}
.sidebar{width:220px;flex-shrink:0;background:var(--navy);position:fixed;top:0;left:0;height:100vh;overflow-y:auto;z-index:100}
.main{margin-left:220px;flex:1}
.inner{max-width:900px;margin:0 auto;padding:32px 32px 80px}
.sidebar-logo{padding:24px 20px 16px;border-bottom:1px solid rgba(255,255,255,.07)}
.sidebar-logo .ticker{font-size:22px;font-weight:700;color:#fff;letter-spacing:-.5px}
.sidebar-logo .name{font-size:11px;color:var(--muted);margin-top:2px}
.sidebar-score{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.07)}
.score-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(37,99,235,.25);border:1px solid rgba(59,130,246,.4);border-radius:20px;padding:6px 14px;color:#93c5fd;font-size:12px;font-weight:600}
.score-pill .num{font-size:18px;font-weight:700;color:#fff}
.sidebar nav{padding:12px 0 24px}
.nav-gl{padding:6px 20px 4px;font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:rgba(148,163,184,.5)}
.nav-link{display:flex;align-items:center;gap:8px;padding:7px 20px;color:rgba(148,163,184,.85);text-decoration:none;font-size:12px;transition:background .15s,color .15s;border-left:2px solid transparent}
.nav-link:hover{background:rgba(255,255,255,.05);color:#fff;border-left-color:var(--blue-l)}
.nav-link .dot{width:6px;height:6px;border-radius:50%;background:var(--muted);flex-shrink:0}
.bull .dot{background:var(--green)} .bear .dot{background:var(--red)} .neut .dot{background:var(--amber)}
.cover{background:linear-gradient(135deg,#0f172a 0%,#1a3a52 55%,#0d6e3f 100%);border-radius:var(--r);padding:40px 40px 36px;margin-bottom:24px;position:relative;overflow:hidden;color:#fff}
.cover::before{content:'{{ ticker }}';position:absolute;right:-16px;top:-8px;font-size:140px;font-weight:800;letter-spacing:-8px;opacity:.05;pointer-events:none}
.cover-label{display:inline-block;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:4px;padding:2px 10px;font-size:10px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;color:#6ee7b7;margin-bottom:14px}
.cover h1{font-size:28px;font-weight:700;line-height:1.2;margin-bottom:4px}
.cover .exchange{font-size:13px;color:rgba(148,163,184,.8);margin-bottom:28px}
.kpi-strip{display:flex;gap:28px;flex-wrap:wrap}
.kpi-strip .k label{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:rgba(148,163,184,.7);margin-bottom:3px}
.kpi-strip .k span{font-size:20px;font-weight:700;color:#fff}
.kpi-strip .k small{font-size:11px;color:rgba(148,163,184,.7);margin-left:4px}
.kpi-strip .k .dn{color:var(--red)}.kpi-strip .k .up{color:var(--green)}
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:28px;margin-bottom:20px;box-shadow:var(--sh);scroll-margin-top:24px}
.card-header{display:flex;align-items:center;gap:10px;padding-bottom:18px;margin-bottom:20px;border-bottom:1px solid var(--border)}
.card-num{width:26px;height:26px;border-radius:6px;background:var(--navy);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.card-title{font-size:15px;font-weight:700;color:var(--text)}
.card-sub{font-size:12px;color:var(--slate);margin-left:auto}
.card h3{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--slate);margin:20px 0 10px}
.card h3:first-of-type{margin-top:0}
.t-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:6px;margin:12px 0}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{background:var(--bg)}
th{padding:9px 12px;text-align:left;font-size:10px;font-weight:600;letter-spacing:.4px;text-transform:uppercase;color:var(--slate);border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:9px 12px;border-bottom:1px solid #f1f5f9}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafbff}
.up{color:var(--green);font-weight:600} .dn{color:var(--red);font-weight:600} .nu{color:var(--amber);font-weight:600} .hi{background:#f0fdf4}
.tags{display:flex;flex-wrap:wrap;gap:5px;margin:8px 0}
.tag{border-radius:4px;padding:2px 8px;font-size:11px;font-weight:500}
.tg{background:#dcfce7;color:#166534} .tr{background:#fee2e2;color:#991b1b} .ta{background:#fef3c7;color:#92400e} .tb{background:#dbeafe;color:#1e40af}
.bars{display:flex;flex-direction:column;gap:8px;margin:10px 0}
.bar-row{display:flex;align-items:center;gap:10px}
.bar-row .bl{min-width:150px;font-size:12px;color:var(--text)}
.bar-row .btr{flex:1;height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden}
.bar-row .bfill{height:100%;border-radius:3px}
.bar-row .bv{min-width:52px;text-align:right;font-size:11px;font-weight:600;color:var(--slate)}
.chart-wrap{position:relative;margin:16px 0}
.chart-wrap canvas{max-height:260px}
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:16px 0}
@media(max-width:680px){.chart-grid{grid-template-columns:1fr}}
.signal{border:1.5px solid var(--blue);border-radius:8px;overflow:hidden;margin-top:22px}
.signal-head{background:var(--navy);padding:9px 18px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#93c5fd;text-align:center}
.signal-rows{display:grid;grid-template-columns:1fr 1fr}
.sr{padding:9px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.sr:nth-child(odd){background:var(--bg)}
.sr label{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--muted)}
.sr span{font-size:12px;font-weight:700}
.signal-foot{background:var(--bg);padding:8px 16px;font-size:10px;color:var(--muted);text-align:center;border-top:1px solid var(--border)}
.verdict{background:var(--navy);border-radius:10px;padding:28px 32px;color:#fff;margin-top:24px}
.verdict h2{font-size:18px;font-weight:700;margin-bottom:20px;color:#fff}
.verdict-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.verdict ul{padding-left:16px;line-height:2;font-size:12px;color:#cbd5e1}
.verdict-score{display:flex;align-items:center;justify-content:center;flex-direction:column;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:24px;text-align:center}
.verdict-score .big{font-size:52px;font-weight:800;color:#60a5fa;line-height:1}
.verdict-score .lbl{font-size:11px;color:#94a3b8;margin-top:6px;text-transform:uppercase;letter-spacing:.5px}
.verdict-score .rec{margin-top:12px;background:rgba(37,99,235,.4);border-radius:20px;padding:4px 14px;font-size:12px;font-weight:600;color:#93c5fd}
.note{background:#fffbeb;border-left:3px solid var(--amber);border-radius:0 6px 6px 0;padding:10px 14px;font-size:11px;color:#78350f;margin-top:14px}
footer{text-align:center;padding:16px 0 32px;font-size:11px;color:var(--muted)}
.sidebar::-webkit-scrollbar{width:4px}
.sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15);border-radius:2px}
@media(max-width:760px){.sidebar{position:static;width:100%;height:auto}.layout{display:block}.main{margin-left:0}.inner{padding:20px}.chart-grid,.verdict-grid{grid-template-columns:1fr}.signal-rows{grid-template-columns:1fr}}
@media print{.sidebar{display:none}.main{margin-left:0}.inner{max-width:none;padding:18px}.card{break-inside:avoid;box-shadow:none}.cover{break-inside:avoid}body{background:#fff}}
</style>
</head>
<body>
<div class="layout">

{# ── 侧边栏 ── #}
<aside class="sidebar">
  <div class="sidebar-logo"><div class="ticker">{{ ticker }}</div><div class="name">{{ company_name }}</div></div>
  {% if composite_rank_8 %}
  <div class="sidebar-score"><div class="score-pill">🏆 <span class="num">{{ composite_rank_8 }}</span></div></div>
  {% endif %}
  <nav>
    <div class="nav-gl">分析章节</div>
    {% for sid, label in SECTION_LABELS.items() %}
    <a class="nav-link {{ sidebar_dots.get(sid, 'bull') }}" href="#{{ sid }}">
      <span class="dot"></span>{{ sid|upper }}. {{ label }}
    </a>
    {% endfor %}
    <div class="nav-gl" style="margin-top:8px">结论</div>
    <a class="nav-link" href="#verdict"><span class="dot" style="background:#60a5fa"></span>最终裁决</a>
  </nav>
</aside>

<main class="main"><div class="inner">

{# ── 封面 ── #}
<div class="cover">
  <div class="cover-label">InvestSkill v2.0 · 综合投资分析报告</div>
  <h1>{{ ticker }} — {{ cover_title }}</h1>
  <div class="exchange">分析日期 {{ report_date }} | 当前价格: {{ cover_price }} | 市值: {{ cover_market_cap }} | {{ exchange }}</div>
  <div class="kpi-strip">
    {% for kpi in cover_kpi %}
    <div class="k"><label>{{ kpi.label }}</label>
      <span class="{{ kpi.css_class or '' }}">{{ kpi.value }}</span>
      {% if kpi.sub %}<small>{{ kpi.sub }}</small>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>

{# ── S1: 涨跌比例总览 ── #}
<div class="card" id="s1">
  <div class="card-header"><div class="card-num">1</div><div class="card-title">📊 涨跌比例总览</div><div class="card-sub">整体分析 · 百分比优先</div></div>
  <div class="t-wrap">
    <table>
      <thead><tr><th>维度</th><th>涨跌比例</th><th>对应价格/估值</th><th>概率权重</th><th>行业对比</th></tr></thead>
      <tbody>
        {% for row in s1_price_changes %}
        <tr>
          <td>{{ row.dimension }}</td>
          <td class="{% if row.change_pct.startswith('+') %}up{% elif row.change_pct.startswith('-') %}dn{% else %}nu{% endif %}">{{ row.change_pct }}</td>
          <td>{{ row.corresponding_price }}</td>
          <td>{{ row.probability_weight }}</td>
          <td>{{ row.industry_compare }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if s1_core_judgment %}<p style="margin-top:12px">{{ s1_core_judgment }}</p>{% endif %}
</div>

{# ── S2: 公司/资产概览 ── #}
<div class="card" id="s2">
  <div class="card-header"><div class="card-num">2</div><div class="card-title">{{ s2.title if s2 else '🏢 公司概览' }}</div><div class="card-sub">{{ s2.subtitle if s2 else '' }}</div></div>
  {% if s2 and s2.body_html %}{{ s2.body_html | safe }}{% endif %}
  {% if s2 and s2.key_metrics %}
  <div class="t-wrap"><table>
    <thead><tr><th>指标</th><th>数值</th><th>说明</th></tr></thead>
    <tbody>
      {% for m in s2.key_metrics %}
      <tr><td>{{ m.label }}</td><td><strong>{{ m.value }}</strong></td><td>{{ m.note or '' }}</td></tr>
      {% endfor %}
    </tbody>
  </table></div>
  {% endif %}
</div>

{# ── S3: 过去一年走势 ── #}
<div class="card" id="s3">
  <div class="card-header"><div class="card-num">3</div><div class="card-title">📈 过去一年走势</div><div class="card-sub">2025.04 — 2026.05</div></div>
  {% if s3_body_html %}{{ s3_body_html | safe }}{% endif %}
  {% for chart in charts if chart.section_id == 's3' %}
  <div class="chart-wrap"><canvas id="{{ chart.chart_id }}"></canvas></div>
  {% endfor %}
</div>

{# ── S4: 竞争格局 ── #}
<div class="card" id="s4">
  <div class="card-header"><div class="card-num">4</div><div class="card-title">{{ s4.title if s4 else '⚔️ 竞争格局' }}</div><div class="card-sub">{{ s4.subtitle if s4 else '' }}</div></div>
  {% if s4 and s4.body_html %}{{ s4.body_html | safe }}{% endif %}
</div>

{# ── S5: 估值分析 ── #}
<div class="card" id="s5">
  <div class="card-header"><div class="card-num">5</div><div class="card-title">💰 估值分析</div><div class="card-sub">DCF · 倍数</div></div>

  {% if f_score_items %}
  {% if is_pos_crypto %}
  <h3>🛡️ Crypto F-Score: {{ f_score_total }}/6</h3>
  {% else %}
  <h3>🛡️ Piotroski F-Score: {{ f_score_total }}/9</h3>
  {% endif %}
  <div class="t-wrap"><table>
    <thead><tr><th>组</th><th>指标</th><th>得分</th><th>说明</th></tr></thead>
    <tbody>
      {% for item in f_score_items %}
      <tr class="{% if item.score == 1 %}hi{% endif %}">
        <td>{{ item.group }}</td><td>{{ item.criterion }}</td>
        <td style="text-align:center;font-weight:700">{{ item.score }}</td><td>{{ item.reason }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table></div>
  {% endif %}

  {% if greenblatt_ranking %}
  <h3>📊 四层加权排名 · {{ composite_rank_8 }}</h3>
  <div class="t-wrap"><table>
    <thead><tr><th>Layer</th><th>维度</th><th>主指标</th><th>数值</th><th>权重</th><th>排名</th><th>判断</th></tr></thead>
    <tbody>
      {% for row in greenblatt_ranking %}
      <tr>
        <td>{{ row.layer }}</td>
        <td>{{ row.dimension }}</td>
        <td>{{ row.metric }}</td>
        <td>{{ row.value }}</td>
        <td style="text-align:center">{{ row.weight }}</td>
        <td style="text-align:center;font-weight:700">{{ row.rank }}</td>
        <td>{{ row.verdict }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table></div>
  {% endif %}

  {% if ranking_summary %}
  <div class="note">☝️ {{ ranking_summary }}</div>
  {% endif %}

  {% if s5_body_html %}{{ s5_body_html | safe }}{% endif %}

  <div class="model-box">
    <div class="mb-head">模型分析 · DCF 情景假设</div>
    <div class="bars">
      {% for m in s5_valuation_methods if m.name in ['DCF保守','DCF基准','DCF乐观','悲观','基准','乐观'] %}
      <div class="bar-row">
        <div class="bl">{{ m.name }}</div>
        <div class="btr"><div class="bfill" style="width:{% if m.probability %}{{ m.probability.replace('%','') }}{% endif %}%;background:var(--blue)"></div></div>
        <div class="bv">{{ m.value }}</div>
      </div>
      {% else %}
      <p style="color:var(--muted);font-size:12px">无模型估值假设</p>
      {% endfor %}
    </div>
  </div>

  {% for m in s5_valuation_methods if m.name not in ['DCF保守','DCF基准','DCF乐观','悲观','基准','乐观'] %}
  {% if loop.first %}
  <div class="real-data-box">
    <div class="rd-head">真实数据参考</div>
    <div class="bars">
  {% endif %}
      <div class="bar-row">
        <div class="bl">{{ m.name }}</div>
        <div class="btr"><div class="bfill" style="width:{% if m.probability %}{{ m.probability.replace('%','') }}{% endif %}%;background:var(--green)"></div></div>
        <div class="bv">{{ m.value }}</div>
      </div>
  {% if loop.last %}
    </div>
  </div>
  {% endif %}
  {% endfor %}

  {% for chart in charts if chart.section_id == 's5' %}
  <div class="chart-wrap"><canvas id="{{ chart.chart_id }}"></canvas></div>
  {% endfor %}
</div>

{# ── S6: 未来一年展望 ── #}
<div class="card" id="s6">
  <div class="card-header"><div class="card-num">6</div><div class="card-title">🔮 未来一年展望</div><div class="card-sub">2026.05 — 2027.05 · 情景概率</div></div>
  {% if s6_body_html %}{{ s6_body_html | safe }}{% endif %}

  {% if s6_scenarios %}
  <div class="model-box">
    <div class="mb-head">模型分析 · 情景假设</div>
    <div class="t-wrap"><table>
      <thead><tr><th>情景</th><th>概率</th><th>目标价</th><th>预期回报</th><th>描述</th></tr></thead>
      <tbody>
        {% for s in s6_scenarios if '分析师' not in s.scenario %}
        <tr>
          <td>{{ s.scenario }}</td><td>{{ s.probability }}</td><td>{{ s.price_target }}</td>
          <td class="{% if s.return_pct.startswith('+') %}up{% elif s.return_pct.startswith('-') %}dn{% else %}nu{% endif %}">{{ s.return_pct }}</td>
          <td>{{ s.description }}</td>
        </tr>
        {% else %}
        <tr><td colspan="5" style="color:var(--muted);text-align:center">无模型情景假设</td></tr>
        {% endfor %}
      </tbody>
    </table></div>
  </div>

  {% for s in s6_scenarios if '分析师' in s.scenario %}
  {% if loop.first %}
  <div class="real-data-box">
    <div class="rd-head">真实数据参考</div>
    <div class="t-wrap"><table>
      <thead><tr><th>情景</th><th>概率</th><th>目标价</th><th>预期回报</th><th>描述</th></tr></thead>
      <tbody>
  {% endif %}
        <tr>
          <td>{{ s.scenario }}</td><td>{{ s.probability }}</td><td>{{ s.price_target }}</td>
          <td class="{% if s.return_pct.startswith('+') %}up{% elif s.return_pct.startswith('-') %}dn{% else %}nu{% endif %}">{{ s.return_pct }}</td>
          <td>{{ s.description }}</td>
        </tr>
  {% if loop.last %}
      </tbody>
    </table></div>
  </div>
  {% endif %}
  {% endfor %}
  {% endif %}

  {% for chart in charts if chart.section_id == 's6' %}
  <div class="chart-wrap"><canvas id="{{ chart.chart_id }}"></canvas></div>
  {% endfor %}
</div>

{# ── S7: 风险矩阵 ── #}
<div class="card" id="s7">
  <div class="card-header"><div class="card-num">7</div><div class="card-title">⚠️ 风险矩阵</div><div class="card-sub">概率 × 估计影响</div></div>
  {% if s7_risks %}
  <div class="t-wrap"><table>
    <thead><tr><th>风险</th><th>概率</th><th>影响</th><th>应对</th></tr></thead>
    <tbody>
      {% for r in s7_risks %}
      <tr><td>{{ r.risk }}</td><td>{{ r.probability }}</td><td>{{ r.impact }}</td><td>{{ r.mitigation }}</td></tr>
      {% endfor %}
    </tbody>
  </table></div>
  {% endif %}
</div>

{# ── S8: 投资信号 ── #}
<div class="card" id="s8">
  <div class="card-header"><div class="card-num">8</div><div class="card-title">🎯 投资信号</div><div class="card-sub">Investment Signal Block</div></div>
  {% if s8_signal %}
  <div class="signal">
    <div class="signal-head">投资信号</div>
    <div class="signal-rows">
      <div class="sr"><label>信号</label><span class="{% if s8_signal.signal == '看多' %}up{% elif s8_signal.signal == '看空' %}dn{% endif %}">{{ s8_signal.signal }}</span></div>
      <div class="sr"><label>信心度</label><span>{{ s8_signal.confidence }}</span></div>
      <div class="sr"><label>投资期限</label><span>{{ s8_signal.horizon }}</span></div>
      <div class="sr"><label>评分</label><span>{{ f_score_total }} / {% if is_pos_crypto %}6{% else %}9{% endif %}</span></div>
    </div>
    <div class="signal-rows">
      <div class="sr"><label>建议操作</label><span>{{ s8_signal.action }}</span></div>
      <div class="sr"><label>确信度</label><span>{{ s8_signal.conviction }}</span></div>
    </div>
    <div class="signal-foot">教育性分析，不构成投资建议</div>
  </div>
  {% endif %}
</div>

{# ── Verdict ── #}
<div id="verdict" style="scroll-margin-top:24px">
  {% if verdict %}
  <div class="verdict">
    <h2>{{ verdict.title }}</h2>
    <div class="verdict-grid">
      <div>
        <h3 style="color:#6ee7b7;font-size:12px;margin-bottom:10px">✅ 看多理由</h3>
        <ul>{% for p in verdict.bull_points %}<li>{{ p }}</li>{% endfor %}</ul>
      </div>
      <div>
        <h3 style="color:#fca5a5;font-size:12px;margin-bottom:10px">⚠️ 看空理由</h3>
        <ul>{% for p in verdict.bear_points %}<li>{{ p }}</li>{% endfor %}</ul>
      </div>
    </div>
    <div class="verdict-score">
      <div class="big">{{ f_score_total }}/{% if is_pos_crypto %}6{% else %}9{% endif %}</div>
      <div class="lbl">{% if is_pos_crypto %}Crypto F-Score · 链上健康度{% else %}Piotroski F-Score · 财务健康度{% endif %}</div>
      <div class="rec">{{ verdict.recommendation }}</div>
    </div>
  </div>
  {% endif %}
</div>

<footer>{{ footer_text }}</footer>

</div></main>
</div>

{# ── 图表 JS (宏生成) ── #}
<script>
const G='#059669',A='#d97706',R='#dc2626',B='#2563eb',S='#94a3b8';
{% for chart in charts %}
{% if chart.chart_type == 'line' %}
{# LINE CHART #}
new Chart(document.getElementById('{{ chart.chart_id }}'),{
  type:'line',
  data:{
    labels:{{ chart.labels | tojson | safe }},
    datasets:[
      {% for ds in chart.datasets %}
      {
        label:'{{ ds.label }}',
        data:{{ ds.data | tojson | safe }},
        borderColor:'{{ ds.color }}',
        backgroundColor:{% if ds.fill %}'{{ ds.color | css_alpha(0.1) }}'{% else %}undefined{% endif %},
        fill:{{ 'true' if ds.fill else 'false' }},
        tension:{{ ds.tension }},
        pointRadius:{{ ds.point_radius }},
        borderWidth:{{ ds.border_width }},
        {% if ds.border_dash %}borderDash:{{ ds.border_dash | tojson | safe }},{% endif %}
        {% if ds.point_background_color %}pointBackgroundColor:'{{ ds.point_background_color }}',{% endif %}
        {% if ds.point_background_colors %}pointBackgroundColor:{{ ds.point_background_colors | tojson | safe }},{% endif %}
        {% if ds.y_axis_id %}yAxisID:'{{ ds.y_axis_id }}',{% endif %}
        pointHoverRadius:5
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  },
  options:{
    responsive:true,
    plugins:{
      legend:{position:'top',labels:{font:{size:11}}}
    },
    scales:{
      x:{grid:{display:false}},
      y:{
        {% if chart.y_min is not none %}min:{{ chart.y_min }},{% endif %}
        {% if chart.y_max is not none %}max:{{ chart.y_max }},{% endif %}
        ticks:{callback:function(v){return '{{ chart.tooltip_prefix }}'+v+'{{ chart.tooltip_suffix }}'}},
        grid:{color:'#f1f5f9'}
      }
    }
  }
});
{% elif chart.chart_type == 'bar' %}
{# BAR CHART #}
new Chart(document.getElementById('{{ chart.chart_id }}'),{
  type:'bar',
  data:{
    labels:{{ chart.labels | tojson | safe }},
    datasets:[
      {% for ds in chart.datasets %}
      {
        label:'{{ ds.label }}',
        data:{{ ds.data | tojson | safe }},
        backgroundColor:{% if ds.point_background_colors %}{{ ds.point_background_colors | tojson | safe }}{% else %}'{{ ds.color }}'{% endif %},
        borderRadius:4,
        barPercentage:0.7
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  },
  options:{
    responsive:true,
    {% if chart.horizontal %}indexAxis:'y',{% endif %}
    plugins:{
      legend:{display:false},
      tooltip:{callbacks:{label:function(c){return '{{ chart.tooltip_prefix }}'+c.raw+'{{ chart.tooltip_suffix }}'}}}
    },
    scales:{
      {% if chart.horizontal %}
      x:{grid:{color:'#f1f5f9'},ticks:{callback:function(v){return '{{ chart.tooltip_prefix }}'+v+'{{ chart.tooltip_suffix }}'}}},
      y:{grid:{display:false}}
      {% else %}
      x:{grid:{display:false}},
      y:{
        {% if chart.y_min is not none %}min:{{ chart.y_min }},{% endif %}
        {% if chart.y_max is not none %}max:{{ chart.y_max }},{% endif %}
        ticks:{callback:function(v){return '{{ chart.tooltip_prefix }}'+v+'{{ chart.tooltip_suffix }}'}},
        grid:{color:'#f1f5f9'}
      }
      {% endif %}
    }
  }
});
{% elif chart.chart_type == 'radar' %}
{# RADAR CHART #}
new Chart(document.getElementById('{{ chart.chart_id }}'),{
  type:'radar',
  data:{
    labels:{{ chart.labels | tojson | safe }},
    datasets:[
      {% for ds in chart.datasets %}
      {
        label:'{{ ds.label }}',
        data:{{ ds.data | tojson | safe }},
        borderColor:'{{ ds.color }}',
        backgroundColor:'{{ ds.color | css_alpha(0.15) }}',
        pointBackgroundColor:'{{ ds.color }}',
        borderWidth:{{ ds.border_width }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  },
  options:{
    responsive:true,
    scales:{
      r:{
        min:0,max:100,
        ticks:{stepSize:20,display:false}
      }
    },
    plugins:{legend:{display:false}}
  }
});
{% endif %}
{% endfor %}
</script>
</body>
</html>
